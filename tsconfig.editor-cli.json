{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".tmp/editor-cli",
    "rootDir": ".",
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "commonjs",
    "moduleResolution": "node",
    "types": ["node"],
    "incremental": false,
    "plugins": []
  },
  "include": [
    "src/lib/creator/**/*.ts",
    "src/lib/editor/**/*.ts",
    "src/lib/history.ts",
    "scripts/create-and-export-timeline-project.ts",
    "scripts/import-timeline-project.ts",
    "scripts/export-timeline-project.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
