{
  "name": "clipscribe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "create:timeline-project": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/create-timeline-project.mts",
    "create:news-video": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./scripts/create-news-video.ts",
    "create-and-export:timeline-project": "rm -rf .tmp/editor-cli && ./node_modules/.bin/tsc -p tsconfig.editor-cli.json && node .tmp/editor-cli/scripts/create-and-export-timeline-project.js",
    "import:timeline-project": "rm -rf .tmp/editor-cli && ./node_modules/.bin/tsc -p tsconfig.editor-cli.json && node .tmp/editor-cli/scripts/import-timeline-project.js",
    "export:timeline-project": "rm -rf .tmp/editor-cli && ./node_modules/.bin/tsc -p tsconfig.editor-cli.json && node .tmp/editor-cli/scripts/export-timeline-project.js",
    "lint": "eslint",
    "test": "npm run test:core",
    "test:core": "rm -rf .tmp/test-dist && tsc -p tsconfig.tests.json && node --test $(find .tmp/test-dist/tests/core -name '*.test.js' -print)",
    "test:contracts": "rm -rf .tmp/test-dist && tsc -p tsconfig.tests.json && node --test .tmp/test-dist/tests/core/creator/export-contracts.test.js .tmp/test-dist/tests/core/creator/export-geometry.test.js .tmp/test-dist/tests/core/creator/export-prep.test.js .tmp/test-dist/tests/core/creator/clip-windowing.test.js .tmp/test-dist/tests/core/creator/clip-editing.test.js .tmp/test-dist/tests/core/creator/short-lifecycle.test.js .tmp/test-dist/tests/core/creator/semantic-subtitles.test.js .tmp/test-dist/tests/core/creator/ass-subtitles.test.js .tmp/test-dist/tests/core/creator/encoder-policy.test.js .tmp/test-dist/tests/core/creator/source-playback-profile.test.js .tmp/test-dist/tests/core/creator/text-overlay-canvas.test.js .tmp/test-dist/tests/core/creator/system-export-contract.test.js .tmp/test-dist/tests/core/creator/render-progress-store.test.js .tmp/test-dist/tests/core/creator/render-service.test.js .tmp/test-dist/tests/core/creator/system-render.test.js .tmp/test-dist/tests/core/transcriber/history-updates.test.js .tmp/test-dist/tests/core/transcriber/progress.test.js",
    "benchmark:short-export": "node ./scripts/benchmark-short-export.mjs",
    "benchmark:editor-export": "node ./scripts/benchmark-editor-export.mjs",
    "check:quick": "node ./scripts/check-quick.mjs",
    "check:strict": "./node_modules/.bin/eslint src/lib/creator/core src/lib/creator/local-render.ts src/components/CreatorHub.tsx tests/core/creator tests/core/transcriber/history-updates.test.ts tests/core/transcriber/progress.test.ts && ./node_modules/.bin/tsc --noEmit --pretty false && npm run test:contracts && npm run test"
  },
  "dependencies": {
    "@elevenlabs/elevenlabs-js": "^2.41.1",
    "@ffmpeg/core": "^0.12.10",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@huggingface/transformers": "^3.8.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tabs": "^1.1.13",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "prompts": "^2.4.2",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  }
}
